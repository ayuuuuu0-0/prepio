# PostgreSQL
POSTGRES_USER=prepio
POSTGRES_PASSWORD=prepio
POSTGRES_DB=prepio
DATABASE_URL=postgres://prepio:prepio@localhost:5432/prepio?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Kafka (set DEV_SYNC_EVENTS=true to run without Kafka locally)
KAFKA_BROKERS=localhost:9092
DEV_SYNC_EVENTS=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3002,http://127.0.0.1:3002

# JWT
JWT_SECRET=change-me-in-production-use-32-chars-min

# Service ports
GATEWAY_PORT=8080
USER_SERVICE_PORT=8081
QUESTION_SERVICE_PORT=8082
STREAK_SERVICE_PORT=8083
PROGRESS_SERVICE_PORT=8084
NOTIFICATION_SERVICE_PORT=8085

# Internal service URLs (localhost for native dev, docker hostnames for compose)
USER_SERVICE_URL=http://localhost:8081
QUESTION_SERVICE_URL=http://localhost:8082
STREAK_SERVICE_URL=http://localhost:8083
PROGRESS_SERVICE_URL=http://localhost:8084
NOTIFICATION_SERVICE_URL=http://localhost:8085
